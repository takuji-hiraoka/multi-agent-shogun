#!/usr/bin/env bash
# pre-commit hook for multi-agent-shogun
# Install: ln -sf ../../tools/pre-commit .git/hooks/pre-commit
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
FAIL=0

# ──────────────────────────────────────────────
# 1. bats チェック（必須）
# ──────────────────────────────────────────────
if ! command -v bats &>/dev/null; then
  echo "❌ pre-commit: bats が見つかりません。コミットを阻止します。"
  echo "   インストール方法: sudo npm install -g bats"
  exit 1
fi

# bats-support / bats-assert がなければセットアップ
if [ ! -d "$REPO_ROOT/tests/test_helper/bats-support" ]; then
  echo "📦 bats helpers をセットアップ中..."
  mkdir -p "$REPO_ROOT/tests/test_helper"
  git clone --depth 1 https://github.com/bats-core/bats-support "$REPO_ROOT/tests/test_helper/bats-support" -q
  git clone --depth 1 https://github.com/bats-core/bats-assert "$REPO_ROOT/tests/test_helper/bats-assert" -q
fi

# ──────────────────────────────────────────────
# 2. ユニットテスト実行（TAP出力でSKIPも同時チェック）
# ──────────────────────────────────────────────
# 対象ファイル収集（agent_selfwatch除く、e2e除く）
ALL_TESTS=()
for f in "$REPO_ROOT/tests/"*.bats; do
  [[ "$f" == *agent_selfwatch.bats ]] && continue
  [ -f "$f" ] && ALL_TESTS+=("$f")
done

# tests/unit/ があれば追加
UNIT_DIR="$REPO_ROOT/tests/unit"
if [ -d "$UNIT_DIR" ]; then
  ALL_TESTS+=("$UNIT_DIR")
else
  echo "ℹ️  tests/unit/ が見つかりません。スキップします。"
fi

if [ ${#ALL_TESTS[@]} -eq 0 ]; then
  echo "ℹ️  実行対象テストなし。スキップします。"
else
  echo "🧪 pre-commit: ユニットテスト実行中..."
  TAP_OUTPUT=$(bats "${ALL_TESTS[@]}" --tap 2>&1) || {
    echo "$TAP_OUTPUT"
    echo "❌ ユニットテスト失敗"
    FAIL=1
  }
  if [ "$FAIL" -eq 0 ]; then
    echo "$TAP_OUTPUT" | grep -v "^#" | tail -5

    # SKIP=FAIL ポリシーチェック（同一TAP出力から）
    SKIP_COUNT=$(echo "$TAP_OUTPUT" | grep -c "^ok.*# skip" || true)
    if [ "$SKIP_COUNT" -gt 0 ]; then
      echo "❌ SKIP=FAIL: ${SKIP_COUNT}件のユニットテストがスキップされています"
      FAIL=1
    else
      echo "✅ SKIP=FAIL: 全ユニットテスト実行済み（SKIPなし）"
    fi
  fi
fi

# ──────────────────────────────────────────────
# 3. E2Eテスト実行（RUN_E2E=1 のときのみ）
# ──────────────────────────────────────────────
E2E_DIR="$REPO_ROOT/tests/e2e"
if [ "${RUN_E2E:-0}" != "1" ]; then
  echo "ℹ️  E2Eテスト: スキップ（RUN_E2E=1 で有効化）"
elif [ -d "$E2E_DIR" ]; then
  # VPS専用テスト（vpsタグ付き）を除外して収集
  E2E_TESTS=()
  for f in "$E2E_DIR"/*.bats; do
    [ -f "$f" ] || continue
    # file_tags に vps を含むファイルを除外
    if grep -q "^# bats file_tags=.*vps" "$f"; then
      continue
    fi
    E2E_TESTS+=("$f")
  done

  if [ ${#E2E_TESTS[@]} -eq 0 ]; then
    echo "ℹ️  E2Eテスト対象なし。スキップします。"
  else
    echo "🧪 pre-commit: E2Eテスト実行中（${#E2E_TESTS[@]}ファイル、VPS専用除外）..."
    E2E_OUTPUT=$(bats "${E2E_TESTS[@]}" --tap --jobs 1 2>&1) || {
      echo "$E2E_OUTPUT"
      echo "❌ E2Eテスト失敗"
      FAIL=1
    }
    if [ "$FAIL" -eq 0 ]; then
      echo "$E2E_OUTPUT" | grep -v "^#" | tail -5

      E2E_SKIP_COUNT=$(echo "$E2E_OUTPUT" | grep -c "^ok.*# skip" || true)
      if [ "$E2E_SKIP_COUNT" -gt 0 ]; then
        echo "❌ SKIP=FAIL: ${E2E_SKIP_COUNT}件のE2Eテストがスキップされています"
        FAIL=1
      else
        echo "✅ SKIP=FAIL: 全E2Eテスト実行済み（SKIPなし）"
      fi
    fi
  fi
else
  echo "ℹ️  tests/e2e/ が見つかりません。スキップします。"
fi

# ──────────────────────────────────────────────
# 4. ShellCheck（lib/, scripts/）
# ──────────────────────────────────────────────
echo "🔍 pre-commit: ShellCheck 実行中..."
if ! command -v shellcheck &>/dev/null; then
  echo "❌ pre-commit: shellcheck が見つかりません。コミットを阻止します。"
  echo "   インストール方法: sudo apt-get install shellcheck または brew install shellcheck"
  exit 1
fi

for dir in lib scripts; do
  if [ -d "$REPO_ROOT/$dir" ]; then
    if ! find "$REPO_ROOT/$dir" -name '*.sh' -type f -exec shellcheck -x -S error {} +; then
      echo "❌ ShellCheck 失敗: $dir/"
      FAIL=1
    fi
  fi
done

# ──────────────────────────────────────────────
# 結果
# ──────────────────────────────────────────────
if [ "$FAIL" -eq 1 ]; then
  echo ""
  echo "❌ pre-commit: 上記のチェックが失敗しました。コミットを阻止します。"
  exit 1
fi

echo ""
echo "✅ pre-commit: 全チェック通過"
